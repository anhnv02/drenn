{
  "name": "drenn",
  "version": "0.0.1",
  "private": false,
  "description": "Cross-platform Electron desktop app for driving AI coding agents — unified sessions, chat, and diff review for Claude Code, opencode, and GitHub Copilot, with built-in terminal and MCP support.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhnv02/drenn.git"
  },
  "homepage": "https://github.com/anhnv02/drenn#readme",
  "bugs": {
    "url": "https://github.com/anhnv02/drenn/issues"
  },
  "keywords": [
    "electron",
    "desktop-app",
    "ai-agent",
    "coding-agent",
    "ai-coding-assistant",
    "agentic-coding",
    "llm",
    "claude-code",
    "opencode",
    "github-copilot",
    "developer-tools",
    "ide",
    "mcp",
    "model-context-protocol",
    "monaco-editor",
    "terminal"
  ],
  "main": "./out/main/index.js",
  "author": {
    "name": "anhnv",
    "email": "anhnv3837@gmail.com"
  },
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-builder install-app-deps && chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true",
    "dist": "electron-vite build && electron-builder --mac",
    "dist:dir": "electron-vite build && electron-builder --mac --dir"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.50.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^6.0.0-beta.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "^5.5.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "node-pty@1.1.0": true
  },
  "build": {
    "appId": "dev.drenn.app",
    "productName": "Drenn",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,css,md,yml}": [
      "prettier --write"
    ]
  }
}
